            "type": "grafana-clickhouse-datasource",
            "uid": "ClickHouse"
          },
          "format": 1,
          "queryType": "sql",
          "rawSql": "SELECT toStartOfInterval(timestamp, INTERVAL 1 MINUTE) as time, avg(temperature) as temp, avg(humidity) as humidity FROM sensor_storage.bme280_data WHERE timestamp >= '2026-04-17 00:00:00' AND timestamp < '2026-04-18 00:00:00' GROUP BY time ORDER BY time ASC SETTINGS use_query_cache = 0",
