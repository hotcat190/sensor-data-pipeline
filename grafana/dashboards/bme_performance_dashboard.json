      "title": "Storage & Compression (sensor_storage)",
      "type": "table",
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "ClickHouse"
          },
          "format": 0,
          "queryType": "sql",
          "rawSql": "SELECT table, sum(data_compressed_bytes) AS storage_size, sum(data_uncompressed_bytes) AS raw_size, round(sum(data_uncompressed_bytes) / sum(data_compressed_bytes), 2) AS compression_ratio, sum(rows) AS total_rows FROM system.parts WHERE database = 'sensor_storage' AND active GROUP BY table SETTINGS use_query_cache = 0",
          "refId": "A"
        }
      ]
